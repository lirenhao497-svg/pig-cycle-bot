# 猪周期监控系统 - 环境变量
# 复制此文件为 .env 并填写实际值

# --- Railway 部署 ---
# 部署后由 Railway 自动赋值，本地无需设置
PORT=8000
DATABASE_URL=

# --- Bark 推送 ---（可选）
# 用于向 iPhone 推送预警通知
BARK_KEY=
BARK_URL=https://api.day.app

# --- API 地址 ---（可选）
# 部署后端后设置，前端通过此地址调用 API
API_HOST=http://localhost:8000

# --- 数据路径 ---
# SQLite 数据库文件路径（Railway 上使用 Volume 持久化）
DB_PATH=data/hog_data.db
