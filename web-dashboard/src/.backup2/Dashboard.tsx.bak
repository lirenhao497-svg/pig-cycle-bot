// 猪周期量化监控 - 实时监控大屏（默认页）

import { useEffect } from 'react'
import { Dot } from 'lucide-react'
import { useLatest as useLatestData, useSignals, useCycleStage, useTradeLogs } from '../hooks/useApi'
import { useDashboardStore } from '../stores/dashboardStore'
import { formatDate } from '../utils'
import MetricCard from '../components/MetricCard'
import SignalCard from '../components/SignalCard'
import CyclePanel from '../components/CyclePanel'
import TradeLogPanel from '../components/TradeLogPanel'
import type { LatestData, SignalData, CycleStage, TradeLog as TradeLogItem } from '../types'

/** 实时监控大屏 —— 入口页面 */
export default function Dashboard() {
  const setLastUpdated = useDashboardStore((s) => s.setLastUpdated)
  const setConnected = useDashboardStore((s) => s.setConnected)

  const { data: latest, isLoading: load1, isError: err1 } = useLatestData()
  const { data: signals, isLoading: load2 } = useSignals()
  const { data: cycle, isLoading: load3 } = useCycleStage()
  const { data: logs, isLoading: load4 } = useTradeLogs(5)

  // 更新全局状态
  useEffect(() => {
    if (latest?.date) {
      const clean = String(latest.date).slice(0, 10)
      setLastUpdated(clean)
      setConnected(true)
    }
  }, [latest, setLastUpdated, setConnected])

  const lastUpdated = useDashboardStore((s) => s.lastUpdated)
  const isConnected = useDashboardStore((s) => s.isConnected)

  return (
    <div className="space-y-4">
      {/* 标题栏 */}
      <div className="flex items-center justify-between mb-2">
        <div>
          <h1 className="text-2xl font-bold text-slate-50">猪周期量化监控大屏</h1>
          <p className="text-sm text-slate-500 mt-1">
            数据更新至: {lastUpdated || '--'}
          </p>
        </div>
        <div className="flex items-center gap-1.5 text-sm text-slate-400">
          <Dot size={20} className={isConnected ? 'text-green-500' : 'text-red-500'} />
          {isConnected ? '实时连接' : '连接断开'}
        </div>
      </div>

      {/* 顶部 4 列核心指标 */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <MetricCard title="猪粮比" value={latest?.pig_grain_ratio} change={latest?.pgr_change} />
        <MetricCard title="牧原收盘" value={latest?.muyuan_close} change={latest?.muyuan_change} suffix="元" />
        <MetricCard title="期货 LH0" value={latest?.futures_close} change={latest?.futures_change} decimals={0} suffix="元/吨" />
        <MetricCard title="畜牧指数" value={latest?.hog_index_close} change={latest?.index_change} decimals={1} />
      </div>

      {/* 中部：信号状态(左) + 周期面板(右) */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div className="lg:col-span-2">
          <SignalCard data={signals} isLoading={load2} />
        </div>
        <div>
          <CyclePanel data={cycle} isLoading={load3} />
        </div>
      </div>

      {/* 底部推送记录 */}
      <TradeLogPanel logs={logs} isLoading={load4} />

      {/* 错误提示 */}
      {err1 && (
        <div className="rounded-xl bg-red-500/10 border border-red-500/20 p-4 text-sm text-red-400">
          无法连接后端 API，请确认服务是否启动：<code className="bg-red-900/30 px-1 rounded">python backend.py</code>
        </div>
      )}
    </div>
  )
}
